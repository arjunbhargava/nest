# ~/.config/zsh/secrets.zsh
# ---------------------------------------------------------------------------
# LOCAL ONLY. Never commit this file. ~/nest/install.sh copies this example
# to ~/.config/zsh/secrets.zsh (chmod 600) if that file does not already exist,
# and never overwrites an existing one.
#
# Put API keys and tokens here as plain exports, e.g.:
#
#   export TAVILY_API_KEY="..."
#   export AWS_BEARER_TOKEN_BEDROCK="..."
#   export BROWSERBASE_API_KEY="..."
#
# Keep real values out of the nest repo.
